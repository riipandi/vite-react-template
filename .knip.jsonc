{
    "$schema": "https://unpkg.com/knip@6.17/schema-jsonc.json",
    "entry": ["src/routes.gen.ts"],
    "exclude": ["binaries", "dependencies"],
    "project": ["src/**/*.{ts,tsx}", "!src/components/**/*", "!src/**/*.d.ts"],
    "ignoreExportsUsedInFile": true,
    "tanstack-router": {
        "config": ["tsr.config.json"],
        "entry": ["src/routes.gen.{ts,js}"]
    },
    "paths": {
        "#/*": ["./src/*"],
        "~/*": ["./public/*"]
    }
}
